global outb
global inb

section .text

; void outb(uint16_t port, uint8_t value)
outb:
    ; args:
    ; port = [esp+4] (C calling convention, 32-bit)
    ; value = [esp+8]
    push ebp
    mov ebp, esp

    mov dx, [ebp+8]    ; port
    mov al, [ebp+12]   ; value
    out dx, al

    pop ebp
    ret

inb:
    push ebp
    mov ebp, esp

    mov dx, [ebp+8]
    in al, dx

    pop ebp
    ret
